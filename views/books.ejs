<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Books Catalog - Library OS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  
  <header>
    <a href="/dashboard" class="logo">
      <i class="fa-solid fa-layer-group" style="color: var(--primary-color);"></i>
      Library OS
    </a>
    <nav class="nav-links">
      <a href="/dashboard"><i class="fa-solid fa-house mr-1"></i> Dashboard</a>
      <a href="/books" style="color: #fff;"><i class="fa-solid fa-book mr-1"></i> Books Catalog</a>
      <% if (user && user.role === 'admin') { %>
        <a href="/transactions"><i class="fa-solid fa-right-left mr-1"></i> Transactions</a>
        <a href="/students"><i class="fa-solid fa-users mr-1"></i> Students</a>
      <% } %>
      <a href="/logout"><i class="fa-solid fa-right-from-bracket mr-1"></i> Logout</a>
    </nav>
  </header>

  <div class="container animate-fade-in">
    <div class="flex items-end mb-6" style="justify-content: space-between;">
      <div>
        <h1>Books Catalog</h1>
        <p class="text-muted">Search and explore the library's collection.</p>
      </div>
      
      <!-- OPAC Search -->
      <form action="/books" method="GET" style="display: flex; gap: 0.5rem; align-items: center;">
        <input type="text" name="q" placeholder="Search title, author, ISBN..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" style="width: 300px; margin-bottom: 0;">
        <button type="submit" class="btn btn-secondary">
          <i class="fa-solid fa-search"></i>
        </button>
      </form>
    </div>

    <% if (user && user.role === 'admin') { %>
      <!-- Add Book Form (Admins Only) -->
      <div class="glass-panel mb-8" style="padding: 1.5rem 2rem;">
        <h3 style="margin-bottom: 1rem; border-bottom: 1px solid var(--surface-border); padding-bottom: 0.5rem;">
          <i class="fa-solid fa-plus-circle mr-2" style="color: var(--success-color);"></i> Add New Book
        </h3>
        <form action="/add-book" method="POST" style="display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap;">
          <div class="form-group" style="flex: 1; min-width: 200px; margin-bottom: 0;">
            <label>Title</label>
            <input name="title" placeholder="Book Title" required>
          </div>
          <div class="form-group" style="flex: 1; min-width: 150px; margin-bottom: 0;">
            <label>Author</label>
            <input type="text" name="author_name" placeholder="Author Name" required>
          </div>
          <div class="form-group" style="flex: 1; min-width: 150px; margin-bottom: 0;">
            <label>Category</label>
            <select name="category_id" required style="width: 100%; padding: 0.75rem 1rem; background: rgba(255, 255, 255, 0.05); border: 1px solid var(--surface-border); border-radius: 8px; color: #fff; outline: none;">
              <% categories.forEach(c => { %>
                <option value="<%= c.id %>" style="color: #000;"><%= c.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group" style="flex: 1; min-width: 120px; margin-bottom: 0;">
            <label>ISBN</label>
            <input name="isbn" placeholder="ISBN" required>
          </div>
          <div class="form-group" style="flex: 0.5; min-width: 80px; margin-bottom: 0;">
            <label>Copies</label>
            <input name="copies" type="number" min="1" value="1" required>
          </div>
          <button type="submit" class="btn btn-primary" style="height: 46px;">
            Add Book
          </button>
        </form>
      </div>
    <% } %>

    <!-- Books Table -->
    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th><i class="fa-solid fa-book-open mr-2"></i> Title</th>
            <th><i class="fa-solid fa-pen-nib mr-2"></i> Author</th>
            <th><i class="fa-solid fa-tags mr-2"></i> Category</th>
            <th><i class="fa-solid fa-barcode mr-2"></i> ISBN</th>
            <th><i class="fa-solid fa-layer-group mr-2"></i> Availability</th>
            <th><%= (user && user.role === 'admin') ? 'Action' : 'Due (Days)' %></th>
          </tr>
        </thead>
        <tbody>
          <% if (books && books.length > 0) { %>
            <% books.forEach(book => { %>
            <tr>
              <td style="font-weight: 500;"><%= book.title %></td>
              <td class="text-muted"><%= book.author_name %></td>
              <td><span style="background: rgba(255,255,255,0.1); padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.8rem;"><%= book.category_name %></span></td>
              <td class="text-muted" style="font-family: monospace;"><%= book.isbn %></td>
              <td>
                <% if (book.copies_available > 0) { %>
                  <span style="color: var(--success-color); font-weight: 600;">
                    <%= book.copies_available %> of <%= book.copies_total %>
                  </span>
                <% } else { %>
                  <span style="color: var(--danger-color); font-weight: 600;">
                    Out of Stock
                  </span>
                <% } %>
              </td>
              <td>
                <% if (user && user.role === 'admin') { %>
                  <div style="display: flex; gap: 0.5rem; align-items: center;">
                    <button class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.875rem;" 
                      data-id="<%= book.id %>"
                      data-title="<%= book.title %>"
                      data-author_name="<%= book.author_name %>"
                      data-category="<%= book.category_id %>"
                      data-isbn="<%= book.isbn %>"
                      data-copies="<%= book.copies_total %>"
                      onclick="openEditModal(this)">
                      <i class="fa-solid fa-pen-to-square"></i> Edit
                    </button>
                    <form action="/delete-book" method="POST" style="margin: 0;" onsubmit="return confirm('Are you sure you want to delete this book?');">
                      <input type="hidden" name="id" value="<%= book.id %>">
                      <button type="submit" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.875rem; color: var(--danger-color); border-color: var(--danger-color);">
                        <i class="fa-solid fa-trash"></i>
                      </button>
                    </form>
                  </div>
                <% } else { %>
                  <% if (book.copies_available > 0) { %>
                    <form action="/issue-book" method="POST" style="margin: 0; display: flex; gap: 0.5rem; align-items: center;">
                      <input type="hidden" name="book_id" value="<%= book.id %>">
                      <input type="number" name="borrow_days" min="1" max="10" value="7" required style="width: 60px; padding: 0.4rem; font-size: 0.875rem; border-radius: 4px; border: 1px solid var(--surface-border); background: rgba(255,255,255,0.1); color: #fff;" title="Days to borrow (1-10)">
                      <button type="submit" class="btn btn-primary" style="padding: 0.4rem 0.8rem; font-size: 0.875rem;">
                        Borrow
                      </button>
                    </form>
                  <% } else { %>
                    <button class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.875rem; opacity: 0.5; cursor: not-allowed;" disabled>
                      Reserve
                    </button>
                  <% } %>
                <% } %>
              </td>
            </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="text-center text-muted" style="padding: 3rem;">
                <i class="fa-solid fa-search" style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.5;"></i>
                <p>No books found matching your search.</p>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <% if (user && user.role === 'admin') { %>
  <!-- Edit Book Modal -->
  <div id="editModal" class="modal-backdrop" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 1000; align-items: center; justify-content: center;">
    <div class="glass-panel" style="padding: 2rem; width: 100%; max-width: 500px; animation: slideUp 0.3s ease;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <h3 style="margin: 0;"><i class="fa-solid fa-pen-to-square"></i> Edit Book</h3>
        <button type="button" onclick="closeEditModal()" style="background: none; border: none; color: white; cursor: pointer; font-size: 1.2rem;"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form action="/edit-book" method="POST" id="editForm" style="display: flex; flex-direction: column; gap: 1rem;">
        <input type="hidden" name="id" id="edit-id">
        
        <div class="form-group" style="margin-bottom: 0;">
          <label>Title</label>
          <input name="title" id="edit-title" required>
        </div>
        
        <div style="display: flex; gap: 1rem;">
          <div class="form-group" style="flex: 1; margin-bottom: 0;">
            <label>Author</label>
            <input type="text" name="author_name" id="edit-author" required>
          </div>
          <div class="form-group" style="flex: 1; margin-bottom: 0;">
            <label>Category</label>
            <select name="category_id" id="edit-category" required style="width: 100%; padding: 0.75rem 1rem; background: rgba(255, 255, 255, 0.05); border: 1px solid var(--surface-border); border-radius: 8px; color: #fff; outline: none;">
              <% categories.forEach(c => { %>
                <option value="<%= c.id %>" style="color: #000;"><%= c.name %></option>
              <% }) %>
            </select>
          </div>
        </div>
        
        <div style="display: flex; gap: 1rem;">
          <div class="form-group" style="flex: 2; margin-bottom: 0;">
            <label>ISBN</label>
            <input name="isbn" id="edit-isbn" required>
          </div>
          <div class="form-group" style="flex: 1; margin-bottom: 0;">
            <label>Total Copies</label>
            <input name="copies" id="edit-copies" type="number" min="1" required>
          </div>
        </div>
        
        <button type="submit" class="btn btn-primary" style="margin-top: 1rem; width: 100%;">Save Changes</button>
      </form>
    </div>
  </div>

  <script>
  function openEditModal(btn) {
    document.getElementById('edit-id').value = btn.dataset.id;
    document.getElementById('edit-title').value = btn.dataset.title;
    document.getElementById('edit-author').value = btn.dataset.author_name;
    document.getElementById('edit-category').value = btn.dataset.category;
    document.getElementById('edit-isbn').value = btn.dataset.isbn;
    document.getElementById('edit-copies').value = btn.dataset.copies;
    
    document.getElementById('editModal').style.display = 'flex';
  }

  function closeEditModal() {
    document.getElementById('editModal').style.display = 'none';
  }
  </script>
  <% } %>

  <script>
  function showNotification(message, type = 'success') {
    let container = document.querySelector('.toast-container');
    if (!container) {
      container = document.createElement('div');
      container.className = 'toast-container';
      document.body.appendChild(container);
    }
    
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    
    const icon = type === 'success' ? '<i class="fa-solid fa-circle-check" style="color: var(--success-color)"></i>' : '<i class="fa-solid fa-circle-exclamation" style="color: var(--danger-color)"></i>';
    
    toast.innerHTML = `${icon} <span>${message}</span>`;
    container.appendChild(toast);
    
    setTimeout(() => {
      toast.classList.add('fade-out');
      setTimeout(() => toast.remove(), 300);
    }, 3000);
  }

  // Check for URL params
  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.has('notif')) {
    showNotification(urlParams.get('notif'), urlParams.get('notif_type') || 'success');
    // Clean URL
    const newUrl = window.location.pathname + window.location.search.replace(/[\?&]notif=[^&]+/, '').replace(/&notif_type=[^&]+/, '');
    window.history.replaceState({}, document.title, newUrl);
  }
  </script>
</body>
</html>